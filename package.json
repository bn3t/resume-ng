    "lucide-react": "^0.562.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.34.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^9.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
